{
   "name": "hljs-enhance",
   "version": "2.0.5",
   "description": "Adds a little extra stuff to highlight.js",
   "license": "MIT",
   "type": "module",
   "module": "hljs-enhance.js",
   "browser": "hljs-enhance.js",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/center-key/hljs-enhance.git"
   },
   "homepage": "https://github.com/center-key/hljs-enhance",
   "bugs": "https://github.com/center-key/hljs-enhance/issues",
   "docs": "https://github.com/center-key/hljs-enhance#readme",
   "author": "Center Key (https://centerkey.com)",
   "keywords": [
      "highlightjs",
      "javascript",
      "syntax-highlighting"
   ],
   "jshintConfig": {
      "esversion": 11,
      "strict": "implied",
      "eqeqeq": true,
      "undef": true,
      "unused": true,
      "browser": true,
      "node": true
   },
   "replacerConfig": {
      "macros": {
         "instructions": "Paste the HTML below into the <head> section:\n"
      }
   },
   "runScriptsConfig": {
      "clean": [
         "rimraf docs"
      ],
      "publish": [
         "replacer src/website           docs",
         "replacer src/hljs-enhance.html docs --rename=instructions.txt --header={{macro:instructions}}",
         "replacer --virtual-input .     docs --rename=robots.txt --content=#{{space}}Allow{{space}}bots"
      ]
   },
   "scripts": {
      "pretest": "run-scripts clean publish",
      "test": "jshint . --exclude-path .gitignore",
      "posttest": "html-validator spec.html docs"
   },
   "devDependencies": {
      "@fortawesome/fontawesome-free": "~7.1",
      "dna-engine": "~3.3",
      "highlight.js": "~11.11",
      "jshint": "~2.13",
      "replacer-util": "~1.5",
      "rimraf": "~6.1",
      "run-scripts-util": "~1.3",
      "w3c-html-validator": "~2.2",
      "web-ignition": "~2.5"
   }
}
